generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ScraperJobStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Listing {
  id                          String    @id @default(cuid())
  source                      String
  sourceListingId             String
  title                       String
  coldRentAmount              Decimal?
  warmRentAmount              Decimal?
  priceCurrency               String?
  freeFrom                    DateTime?
  insertedAt                  DateTime?
  isWBSRequired               Boolean?
  floor                       Int?
  maxFloor                    Int?
  yearOfConstruction          Int?
  heatingType                 String?
  energyType                  String?
  energyEfficiencyClass       String?
  energyConsumptionKWhPerYear Decimal?
  address                     String?
  city                        String?
  country                     String?
  areaM2                      Decimal?
  rooms                       Decimal?
  listingUrl                  String
  imageUrls                   String[]
  features                    String[]
  rawData                     Json
  isValid                     Boolean   @default(true)
  firstSeenAt                 DateTime  @default(now())
  lastSeenAt                  DateTime  @updatedAt

  @@unique([source, sourceListingId])
}

model ScraperJob {
  id                String           @id @default(cuid())
  sourceId          String
  status            ScraperJobStatus
  startedAt         DateTime         @default(now())
  finishedAt        DateTime?
  listingsProcessed Int              @default(0)
  listingsUpserted  Int              @default(0)
  errorMessage      String?
}

// ─── Tenant & Application Models ─────────────────────────────────

model Tenant {
  id                  String              @id @default(cuid())
  email               String              @unique
  phone               String?
  whatsappNumber      String?
  name                String
  monthlyNetIncomeEur Int?
  householdSize       Int                 @default(1)
  hasPets             Boolean             @default(false)
  hasSchufa           Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  preferences         TenantPreference?
  documents           TenantDocument[]
  applications        Application[]
  notifications       Notification[]
}

model TenantPreference {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  minRooms           Decimal?
  maxRooms           Decimal?
  maxColdRent        Decimal?
  maxWarmRent        Decimal?
  minAreaM2          Decimal?
  preferredDistricts String[]
  wbsRequired        Boolean?
  autoApplyEnabled   Boolean  @default(false)
}

model TenantDocument {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String // schufa, payslip, id, employment-proof
  fileName   String
  storageUrl String
  uploadedAt DateTime @default(now())
}

enum ApplicationStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model Application {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId       String
  coverLetter     String?
  status          ApplicationStatus @default(PENDING)
  submittedAt     DateTime?
  responseAt      DateTime?
  responseContent String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      String // listing-alert, application-submitted, application-response
  channel   String // email, whatsapp
  payload   Json
  status    String   @default("pending") // pending, sent, failed
  sentAt    DateTime?
  createdAt DateTime @default(now())
}
